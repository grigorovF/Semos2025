<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Reserve Trip</title>
    <link rel="stylesheet" href="/css/reservations.css" />
  </head>

  <body>
    <div class="container">
      <h1>Reserve Trip</h1>

      <form id="reservationForm">
        <label>From Land</label>
        <select id="fromLandSelect">
          <option value="">Select Land</option>
        </select>

        <label>From City</label>
        <select id="fromCitySelect">
          <option value="">Select City</option>
        </select>

        <label>To Land</label>
        <select id="toLandSelect">
          <option value="">Select Land</option>
        </select>

        <label>To City</label>
        <select id="toCitySelect">
          <option value="">Select City</option>
        </select>

        <label>Passengers</label>
        <input type="number" id="passengers" min="1" value="1" />

        <br /><br />

        <button type="submit">Reserve</button>
      </form>
    </div>

    <script src="/js/reservations.js"></script>
  </body>
</html>
