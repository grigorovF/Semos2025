<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login | Agency</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="auth-container">
        <h2>Добредојдовте</h2>
        <form id="loginForm">
            <input type="email" name="email" placeholder="Email адреса" required />
            <input type="password" name="password" placeholder="Лозинка" required />
            <button type="submit">Најави се</button>
        </form>
        <div style="margin-top: 1.5rem;">
            <a href="/forgotPassword">Ја заборавивте лозинката?</a><br><br>
            <span style="font-size: 0.9rem; opacity: 0.7;">Немаш профил?</span> 
            <a href="/register">Регистрирај се</a>
        </div>
    </div>
    <script src="/js/login.js"></script>
</body>
</html>